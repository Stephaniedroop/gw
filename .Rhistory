add_interactions <- function(df, base_causes) {
combs <- combn(base_causes, 2)
new_cols <- apply(combs, 2, function(pair) {
df[[pair[1]]] & df[[pair[2]]]
})
colnames(new_cols) <- apply(combs, 2, paste0, collapse = "")
cbind(df, new_cols)
}
